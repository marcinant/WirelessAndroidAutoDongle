#!/bin/sh
#
# Start the OBD-II logger (Bluetooth ELM327 -> /persist).
#
# OFF BY DEFAULT. This shares the dongle's single Bluetooth radio with the
# Android Auto link, so it only starts when explicitly enabled with a paired
# adapter. Disable again by setting AAWG_OBD_ENABLE=0 or clearing the MAC.
#

PIDFILE="/var/run/aawg-obd.pid"

case "$1" in
	start)
		if [ -z "$AAWG_CONF_SOURCED" ]; then
			echo "Source /etc/aawgd.conf"
			source /etc/aawgd.conf
		fi

		if [ "${AAWG_OBD_ENABLE:-0}" != "1" ] || [ -z "${AAWG_OBD_MAC:-}" ]; then
			echo "OBD logger disabled (set AAWG_OBD_ENABLE=1 and AAWG_OBD_MAC)."
			exit 0
		fi

		printf "Starting OBD logger: "
		start-stop-daemon -S -b -q -m -p "$PIDFILE" -x /usr/bin/aawg-obd
		[ $? = 0 ] && echo "OK" || echo "FAIL"
		;;
	stop)
		printf "Stopping OBD logger: "
		start-stop-daemon -K -q -p "$PIDFILE"
		[ $? = 0 ] && echo "OK" || echo "FAIL"
		;;
	restart)
		$0 stop
		$0 start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		;;
esac
