#!/bin/sh
#
# Start the aawg stats collector (feeds the web UI charts and the
# persistent history used by home-sync)
#

PIDFILE="/var/run/aawg-statsd.pid"

case "$1" in
	start)
		if [ -z "$AAWG_CONF_SOURCED" ]; then
			echo "Source /etc/aawgd.conf"
			source /etc/aawgd.conf
		fi

		if [ "${AAWG_ENABLE_STATS:-1}" = "0" ]; then
			echo "AAWG_ENABLE_STATS is 0. Skipping stats collector."
			exit 0
		fi

		printf "Starting stats collector: "
		start-stop-daemon -S -b -q -m -p "$PIDFILE" -x /usr/sbin/aawg-statsd
		[ $? = 0 ] && echo "OK" || echo "FAIL"
		;;
	stop)
		printf "Stopping stats collector: "
		start-stop-daemon -K -q -p "$PIDFILE"
		[ $? = 0 ] && echo "OK" || echo "FAIL"
		;;
	restart)
		$0 stop
		$0 start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		;;
esac
