#!/bin/sh
#
# aawg-statsd: sample wifi link and stream metrics for the web UI charts and
# keep a compact per-minute history on /persist for the home-sync upload.
#
# Ring buffer (tmpfs, lost on power-off):
#   /var/run/aawg-stats.csv - one sample every $INTERVAL seconds:
#     uptime_s,rx_bytes,tx_bytes,signal_dbm,tx_retries,tx_failed,rtt_ms,aa_session
#   rx/tx are wlan0 interface totals; the web UI derives Mbps from deltas.
#   signal/retries/failed come from the first associated station (the phone).
#   rtt_ms is a single ping to the phone; empty when no station or no reply.
#   aa_session is 1 while the AA proxy TCP session is ESTABLISHED.
#
# History (SD card, survives power cuts):
#   /persist/aawg/history.log - one line per minute:
#     epoch_s uptime_s rx_bytes tx_bytes signal_dbm tx_failed aa_session
#   Rotated to history.log.0 at 256 KB. Uploaded (and renamed to
#   history.log.sent) by aawg-homesync when the dongle boots in home wifi range.
#
# /persist/aawg/last-time holds the last known wall-clock time. Restored at
# start when the clock is obviously wrong (no RTC on the Pi) so log and
# history timestamps stay roughly monotonic across power cuts.

STATS=/var/run/aawg-stats.csv
HIST_DIR=/persist/aawg
HIST=$HIST_DIR/history.log
INTERVAL=3
RING_MAX=1200
RING_KEEP=600
HIST_MAX=262144

mkdir -p "$HIST_DIR"

# No RTC: restore an approximate clock so timestamps are not stuck in 1970
if [ "$(date +%s)" -lt 1700000000 ] && [ -f "$HIST_DIR/last-time" ]; then
	date -s "@$(cat "$HIST_DIR/last-time")" >/dev/null 2>&1
fi

tick=0
while :; do
	sleep "$INTERVAL"
	tick=$((tick + 1))

	[ -d /sys/class/net/wlan0 ] || continue

	up=$(cut -d. -f1 /proc/uptime)
	rx=$(cat /sys/class/net/wlan0/statistics/rx_bytes 2>/dev/null)
	tx=$(cat /sys/class/net/wlan0/statistics/tx_bytes 2>/dev/null)

	sig=""; txretry=""; txfail=""
	eval "$(iw dev wlan0 station dump 2>/dev/null | awk '
		/signal:/ && !s {s=$2}
		/tx retries:/ && !r {r=$3}
		/tx failed:/ && !f {f=$3}
		END {printf "sig=%s txretry=%s txfail=%s", s, r, f}')"

	# RTT to the first associated client (the phone)
	rtt=""
	sta_ip=$(awk '$3 == "0x2" && $6 == "wlan0" {print $1; exit}' /proc/net/arp 2>/dev/null)
	if [ -n "$sta_ip" ]; then
		rtt=$(ping -c 1 -W 1 "$sta_ip" 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p')
	fi

	sess=0
	netstat -tn 2>/dev/null | grep ':5288' | grep -q ESTABLISHED && sess=1

	echo "$up,${rx:-0},${tx:-0},$sig,$txretry,$txfail,$rtt,$sess" >> "$STATS"

	# Ring-rotate the sample buffer
	if [ $((tick % 100)) -eq 0 ] && [ "$(wc -l < "$STATS")" -gt "$RING_MAX" ]; then
		tail -n "$RING_KEEP" "$STATS" > "$STATS.new" && mv "$STATS.new" "$STATS"
	fi

	# Per-minute persistent history + clock checkpoint
	if [ $((tick % (60 / INTERVAL))) -eq 0 ]; then
		now=$(date +%s)
		echo "$now $up ${rx:-0} ${tx:-0} ${sig:--} ${txfail:--} $sess" >> "$HIST"
		[ "$now" -ge 1700000000 ] && echo "$now" > "$HIST_DIR/last-time"
		if [ "$(wc -c < "$HIST")" -gt "$HIST_MAX" ]; then
			mv "$HIST" "$HIST.0"
		fi
	fi
done
